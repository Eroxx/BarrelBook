                        .foregroundColor(.secondary)
                    Text("PPP")
                        .font(.caption)
                        .foregroundColor(.secondary)
                    Divider()
                        .frame(width: 60)
                    Text(formatPricePerProof(averagePricePerProof))
                        .font(.title)
                        .fontWeight(.bold)
                        .lineLimit(1)
                        .minimumScaleFactor(0.5)
                }
                .frame(maxWidth: .infinity)
            }
            
            Divider()
                .padding(.vertical, 8)
            
            Text("Average Price by Type")
                .font(.headline)
                .padding(.bottom, 4)
            
            VStack(alignment: .leading, spacing: 8) {
                ForEach(priceByTypeData.prefix(4)) { item in
                    HStack {
                        Text(item.type)
                            .font(.subheadline)
                        
                        Spacer()
                        
                        Text(formatCurrency(item.averagePrice))
                            .font(.subheadline)
                            .foregroundColor(.secondary)
                    }
                    .padding(.vertical, 2)
                }
            }
        }
    }
    
    private var averagePrice: Double {
        let validPrices = whiskeys.map { $0.price }.filter { $0 > 0 }
        if validPrices.isEmpty { return 0 }
        return validPrices.reduce(0, +) / Double(validPrices.count)
    }
    
    private var totalValue: Double {
        return whiskeys.map { $0.price * Double($0.numberOfBottles) }.reduce(0, +)
    }
    
    private var averagePricePerProof: Double {
        let validWhiskeys = whiskeys.filter { $0.price > 0 && $0.proof > 0 }
        if validWhiskeys.isEmpty { return 0 }
        
        let totalPPP = validWhiskeys.reduce(0.0) { total, whiskey in
            return total + (whiskey.price / whiskey.proof)
        }
        
        return totalPPP / Double(validWhiskeys.count)
    }
    
    private var priceByTypeData: [TypePriceData] {
        var typeGroups: [String: [Double]] = [:]
        
        for whiskey in whiskeys {
            if whiskey.price > 0, let type = whiskey.type, !type.isEmpty {
                if typeGroups[type] == nil {
                    typeGroups[type] = []
                }
                typeGroups[type]?.append(whiskey.price)
            }
        }
        
        return typeGroups.map { type, prices in
            let average = prices.reduce(0, +) / Double(prices.count)
            return TypePriceData(type: type, averagePrice: average, count: prices.count)
        }.sorted { $0.count > $1.count }
    }
    
    private func formatCurrency(_ value: Double) -> String {
        let formatter = NumberFormatter()
        formatter.numberStyle = .currency
        formatter.maximumFractionDigits = 0
        return formatter.string(from: NSNumber(value: value)) ?? "$0"
    }
    
    private func formatPricePerProof(_ value: Double) -> String {
        let formatter = NumberFormatter()
        formatter.numberStyle = .currency
        formatter.maximumFractionDigits = 2
        return formatter.string(from: NSNumber(value: value)) ?? "$0.00"
    }
}

struct TypePriceData: Identifiable {
    let id = UUID()
    let type: String
    let averagePrice: Double
    let count: Int
}

// Add this after the CombinedCollectionStats view implementation

// Detail view shown when a statistics section is tapped
struct StatDetailView: View {
    @Environment(\.managedObjectContext) private var viewContext
    @Environment(\.presentationMode) var presentationMode
    
    var title: String
    var whiskeys: [Whiskey]
    var initialFilter: WhiskeyFilter?
    
    @State private var showingFilterSheet = false
    @State private var currentSort: SortOption = .nameAsc
    @State private var filterOptions = FilterOptions()
    
    @State private var availableTypes: [String] = []
    
    // State variables for sliders
    @State private var priceRange: ClosedRange<Double> = 0...500
    @State private var proofRange: ClosedRange<Double> = 80...160
    
    // Calculate proof range
    private var lowestProof: Double {
        whiskeys.min(by: { $0.proof < $1.proof })?.proof ?? 80
    }
    
    private var highestProof: Double {
        whiskeys.max(by: { $0.proof < $1.proof })?.proof ?? 160
    }
    
    // Initialize filter options with all available types when the view appears
    private func initializeFilterOptions() {
        // If filter options are already initialized with types, don't override
        if filterOptions.selectedTypes.isEmpty {
            filterOptions.selectedTypes = Set(availableTypes)
        }
    }
    
    var body: some View {
        VStack {
            // Active filter indicator
            if initialFilter != nil {
                Text(initialFilter?.displayName ?? "")
                    .font(.subheadline)
                    .foregroundColor(.secondary)
                    .padding(.horizontal)
                    .padding(.top, 8)
            }
            
            List {
                Section(header: Text("FILTERED BOTTLES: \(filteredAndSortedWhiskeys.count)")) {
                    if filteredAndSortedWhiskeys.isEmpty {
                        Text("No bottles match the current filters")
                            .foregroundColor(.secondary)
                            .italic()
                            .padding(.vertical, 8)
                    } else {
                        ForEach(filteredAndSortedWhiskeys, id: \.self) { whiskey in
                            WhiskeyRowView(whiskey: whiskey)
                        }
                    }
                }
            }
        }
        .navigationTitle(title)
        .navigationBarTitleDisplayMode(.inline)
        .toolbar {
            ToolbarItem(placement: .navigationBarTrailing) {
                HStack(spacing: 16) {
                    Button {
                        showingFilterSheet = true
                    } label: {
                        Image(systemName: "line.3.horizontal.decrease.circle")
                    }
                    
                    Menu {
                        ForEach(SortOption.allCases, id: \.self) { option in
                            Button {
                                currentSort = option
                            } label: {
                                HStack {
                                    Text(option.rawValue)
                                    if currentSort == option {
                                        Image(systemName: "checkmark")
                                    }
                                }
                            }
                        }
                    } label: {
                        Image(systemName: "arrow.up.arrow.down")
                    }
                }
            }
        }
        .sheet(isPresented: $showingFilterSheet) {
            FilterView(
                filterOptions: $filterOptions,
                availableTypes: availableTypes,
                showingWhiskeyCount: filteredAndSortedWhiskeys.count,
                totalWhiskeyCount: whiskeys.count,
                lowestProof: lowestProof,
                highestProof: highestProof
            )
        }
        .onAppear {
            // Get available whiskey types for filtering
            availableTypes = Array(Set(whiskeys.compactMap { $0.type })).sorted()
            
            // Apply initial filter if provided
            if let filter = initialFilter {
                applyInitialFilter(filter)
            }
            
            // Initialize filter options to ensure all types are selected by default
            initializeFilterOptions()
        }
    }
    
    // Apply the initial filter from the statistics view
    private func applyInitialFilter(_ filter: WhiskeyFilter) {
        switch filter.type {
        case .type(let type):
            filterOptions.selectedTypes = [type]
        case .proof(let min, let max):
            filterOptions.proofRange = min...max
            // Update the proof range slider for visual feedback
            DispatchQueue.main.async {
                self.proofRange = min...max
            }
        case .attribute(let attr, let value):
            switch attr {
            case "Bottled in Bond":
                filterOptions.isBiB = value
            case "Single Barrel":
                filterOptions.isSiB = value
            case "Store Picks", "Store Pick":
                filterOptions.isStorePick = value
            default:
                break
            }
        case .price(let min, let max):
            filterOptions.customPriceRange = min...max
            // Update the price range slider for visual feedback
            DispatchQueue.main.async {
                self.priceRange = min...(max == Double.infinity ? 500 : max)
            }
        case .tastedStatus(let isTasted):
            // For tasted/untasted status, we'll need to filter in the filteredAndSortedWhiskeys computed property
            // This is handled below
            break
        default:
            break
        }
    }
    
    // Filtered and sorted whiskeys for display
    private var filteredAndSortedWhiskeys: [Whiskey] {
        let filtered = whiskeys.filter { whiskey in
            // If no types are selected, filter out all whiskeys (instead of showing all)
            // If types are selected, only show those types
            let matchesType = !filterOptions.selectedTypes.isEmpty && 
                (whiskey.type != nil && filterOptions.selectedTypes.contains(whiskey.type!))
            
            // Special attribute filtering
            let matchesBiB: Bool
            let matchesSiB: Bool
            let matchesStorePick: Bool
            let matchesHighProof: Bool
            let matchesDistillery: Bool
            
            if let filter = initialFilter {
                switch filter.type {
                case .attribute(let attr, _):
                    // When filtering by a specific attribute, only show whiskeys with that attribute
                    switch attr {
                    case "Bottled in Bond":
                        matchesBiB = whiskey.isBiB
                        matchesSiB = true
                        matchesStorePick = true
                        matchesHighProof = true
                        matchesDistillery = true
                    case "Single Barrel":
                        matchesBiB = true
                        matchesSiB = whiskey.isSiB
                        matchesStorePick = true
                        matchesHighProof = true
                        matchesDistillery = true
                    case "Store Picks", "Store Pick":
                        matchesBiB = true
                        matchesSiB = true
                        matchesStorePick = whiskey.isStorePick
                        matchesHighProof = true
                        matchesDistillery = true
                    case "High Proof":
                        matchesBiB = true
                        matchesSiB = true
                        matchesStorePick = true
                        matchesHighProof = whiskey.proof > 100
                        matchesDistillery = true
                    default:
                        matchesBiB = true
                        matchesSiB = true
                        matchesStorePick = true
                        matchesHighProof = true
                        matchesDistillery = true
                    }
                case .distillery(let distillery):
                    // Filter by distillery
                    matchesBiB = true
                    matchesSiB = true
                    matchesStorePick = true
                    matchesHighProof = true
                    matchesDistillery = whiskey.distillery == distillery
                default:
                    matchesBiB = true
                    matchesSiB = true
                    matchesStorePick = true
                    matchesHighProof = true
                    matchesDistillery = true
                }
            } else {
                // When not filtering by attributes, use the toggle states
                matchesBiB = !whiskey.isBiB || filterOptions.isBiB
                matchesSiB = !whiskey.isSiB || filterOptions.isSiB
                matchesStorePick = !whiskey.isStorePick || filterOptions.isStorePick
                matchesHighProof = true
                matchesDistillery = true
            }
            
            // Price range filtering
            let priceRange = filterOptions.priceRangeOption.range
            let matchesPriceRange: Bool
            
            if let customRange = filterOptions.customPriceRange {
                // Use custom range if set
                matchesPriceRange = whiskey.price >= customRange.lowerBound && 
                    (customRange.upperBound == Double.infinity || whiskey.price <= customRange.upperBound)
            } else {
                // Use predefined range
                matchesPriceRange = filterOptions.priceRangeOption == .all || 
                    (whiskey.price >= priceRange.min && (priceRange.max == Double.infinity || whiskey.price <= priceRange.max))
            }
            
            // Proof range filtering
            let matchesProofRange: Bool
            if let proofRange = filterOptions.proofRange {
                matchesProofRange = whiskey.proof >= proofRange.lowerBound && whiskey.proof <= proofRange.upperBound
            } else {
                matchesProofRange = true
            }
            
            // Check if we're filtering by tasted status
            let matchesTastedStatus: Bool
            if let filter = initialFilter, case let .tastedStatus(isTasted) = filter.type {
                // Determine if the whiskey has been tasted (has journal entries)
                let hasTasted = (whiskey.journalEntries?.count ?? 0) > 0
                matchesTastedStatus = hasTasted == isTasted
            } else {
                matchesTastedStatus = true // No tasted status filter
            }
            
            return matchesType && matchesBiB && matchesSiB && matchesStorePick && 
                   matchesHighProof && matchesDistillery &&
                   matchesPriceRange && matchesProofRange && matchesTastedStatus
        }
        
        return filtered.sorted { first, second in
            switch currentSort {
            case .nameAsc:
                return (first.name ?? "") < (second.name ?? "")
            case .nameDesc:
                return (first.name ?? "") > (second.name ?? "")
            case .proofHigh:
                return first.proof > second.proof
            case .proofLow:
                return first.proof < second.proof
            case .priceHigh:
                return first.price > second.price
            case .priceLow:
                return first.price < second.price
            case .typeAsc:
                return (first.type ?? "") < (second.type ?? "")
            case .ageDesc:
                return (first.age ?? "") > (second.age ?? "")
            case .ageAsc:
                return (first.age ?? "") < (second.age ?? "")
            case .dateAdded:
                // Fallback to name if dateAdded isn't available
                return (first.name ?? "") < (second.name ?? "")
            }
        }
    } 
}